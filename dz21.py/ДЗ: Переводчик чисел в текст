try:
    number = int(input("Введите число в диапазоне от 1 до 5: "))
    if number == 1:
      print("Соответствующее слово: One")
    elif number == 2:
      print("Соответствующее слово: Two")
    elif number == 3:
      print("Соответствующее слово: Three")
    elif number == 4:
      print("Соответствующее слово: Four")
    elif number == 5:
      print("Соответствующее слово: Five")
    else:
      print("Вы не попали в диапазон от 1 до 5, попробуйте позже")
except ValueError:
       print("Ошибка: введено не число!")
